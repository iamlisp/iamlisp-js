; Fibonacci using tail-call optimization.
; iter carries the current and next values. Its recursive call is the final
; expression, so evaluation does not need to retain the previous continuation.

(defun fib-tail (n)
  (defun iter (i x y)
    (cond ((<= i 0) x) ((iter (dec i) y (+ x y)))))
  (iter n 0 1))

; => 55
(fib-tail 10)

#!iamlisp layout-v1
; Recursive Fibonacci using layout-v1 syntax.
; Any indentation increase opens one level. Matching indentation stays at the
; same level. Inline parentheses remain available for nested expressions.

defun fib (n)
  cond
       (<= n 1) n
       else
          + (fib (- n 1)) (fib (- n 2))

fib 10
